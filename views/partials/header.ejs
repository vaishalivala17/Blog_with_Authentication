<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'BlogApp' %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary-color: #E50914;
            --dark-bg: #141414;
            --card-bg: #1f1f1f;
            --text-light: #f5f5f5;
            --text-muted: #b3b3b3;
            --bs-body-bg: #1f1f1f;
        }
        .btn-outline-light {
            --bs-btn-active-color: #fff;
        }   
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--dark-bg);
            color: var(--text-light);
            min-height: 100vh;
        }

        img {
            color: var(--text-light);
        }

        .form-control::placeholder {
            color: #ffffff !important;
            opacity: 0.8;
        }
        .form-control {
            color: #ffffff !important;
        }

        .navbar {
            background-color: rgba(20, 20, 20, 0.95) !important;
            padding: 15px 0;
            backdrop-filter: blur(10px);
        }

        .navbar-brand {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-color) !important;
            letter-spacing: 2px;
        }

        .nav-link {
            color: var(--text-light) !important;
            font-weight: 500;
            transition: all 0.3s ease;
            padding: 8px 15px !important;
            border-radius: 5px;
        }

        .nav-link:hover {
            color: var(--primary-color) !important;  
            background-color: rgba(229, 9, 20, 0.1);
        }

        /* Prevent dropdown button hover color change */
        .dropdown-toggle:hover {
            color: var(--text-light) !important;
            background-color: rgba(229, 9, 20, 0.1) !important;
            padding: 8px 15px !important;
            border-radius: 5px;
            margin: 0 5px;
        }

        .navbar-toggler {
            border-color: var(--primary-color);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(229, 9, 20, 1)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        .btn-netflix {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 4px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-netflix:hover {
            background-color: #f40612;
            color: white;
            transform: scale(1.05);
        }

        .btn-outline-netflix {
            background-color: transparent;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
            padding: 8px 20px;
            border-radius: 4px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-outline-netflix:hover {
            background-color: var(--primary-color);
            color: white;
        }

        .dropdown-menu {
            background-color: var(--card-bg);
            border: 1px solid #333;
        }

        .dropdown-item {
            color: var(--text-light) !important;
        }

        .dropdown-item:hover {
            background-color: rgba(229, 9, 20, 0.1);
            color: var(--text-light) !important;
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark-bg);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary-color);
            border-radius: 4px;
        }

        /* Toast notifications */
        .toast-container {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
        }

        .custom-toast {
            background-color: var(--card-bg);
            border-left: 4px solid var(--primary-color);
            color: var(--text-light);
            padding: 15px 20px;
            margin-bottom: 10px;
            border-radius: 5px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Page Title Styles */
        .page-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #E50914 !important;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            margin-bottom: 1rem;
        }

        .page-subtitle {
            font-size: 1.1rem;
            color: #e0e0e0;
        }

        /* Like Button Styles */
        .btn-liked {
            background-color: #FF0000;
            color: white;
            border: 2px solid #FF0000;
        }

        .btn-liked:hover {
            background-color: #cc0000;
            color: white;
        }

        .btn-unliked {
            background-color: transparent;
            color: white;
            border: 2px solid white;
        }

        .btn-unliked:hover {
            background-color: white;
            color: black;
        }

        /* Mobile Navbar Fixes */
        @media (max-width: 991.98px) {
            .navbar-nav .nav-item .dropdown-toggle:hover,
            .navbar-nav .nav-item .dropdown-item:hover {
                color: var(--text-light) !important;
                background-color: rgba(229, 9, 20, 0.1) !important;
            }
            .navbar-nav .nav-item:not(.dropdown) .btn {
                display: block;
                width: 100%;
                margin: 5px 0;
                text-align: left;
            }
            .navbar-nav .dropdown-menu {
                position: static !important;
                float: none;
                width: auto;
                margin-top: 0;
                background-color: transparent;
                border: 0;
                box-shadow: none;
            }
            .navbar-nav .dropdown-item {
                padding-left: 20px;
            }
        }
    </style>
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-play-circle me-2"></i>BLOGFLIX
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home me-1"></i> Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/search"><i class="fas fa-search me-1"></i> Search</a>
                    </li>
                    <% if (typeof user !=='undefined' && user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/dashboard"><i class="fas fa-tachometer-alt me-1"></i>
                                Dashboard</a>
                        </li>
                        <% if (typeof isAdmin !=='undefined' && isAdmin) { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/users"><i class="fas fa-users-cog me-1"></i> Users</a>
                            </li>
                            <% } %>
                                <% } %>
                </ul>
                <ul class="navbar-nav">
                    <% if (typeof user !=='undefined' && user) { %>
                            <li class="nav-item dropdown">
                            <button class="btn btn-outline-light dropdown-toggle p-0 border-0 bg-transparent" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="line-height: 1;">
                                <img src="<%= user.profileImage || '/uploads/blogs/default-avatar.png' %>" alt="Profile" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover; border: 2px solid var(--primary-color);">
                                <span class="ms-1 d-none d-md-inline" style="max-width: 120px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    <%= user.username %>
                                </span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/profile"><i class="fas fa-user me-2"></i> Profile</a></li>
                                <li><a class="dropdown-item" href="/dashboard"><i class="fas fa-blog me-2"></i> My Blogs</a></li>
                                <li><a class="dropdown-item" href="/blog/create"><i class="fas fa-plus-circle me-2"></i> Create Blog</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/logout"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
                            </ul>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="btn btn-outline-netflix me-2" href="/login"><i
                                        class="fas fa-sign-in-alt me-1"></i> Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-netflix" href="/register"><i class="fas fa-user-plus me-1"></i>
                                    Register</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Spacer for fixed navbar -->
    <div style="height: 80px;"></div>

    <!-- Toast Container -->
    <div class="toast-container">
        <% if (typeof message !=='undefined' && message) { %>
            <div class="custom-toast">
                <i class="fas fa-check-circle text-success me-2"></i>
                <%= message %>
            </div>
            <% } %>
                <% if (typeof error !=='undefined' && error) { %>
                    <div class="custom-toast" style="border-left-color: #dc3545;">
                        <i class="fas fa-exclamation-circle text-danger me-2"></i>
                        <%= error %>
                    </div>
                    <% } %>
    </div>