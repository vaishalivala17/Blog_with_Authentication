<%- include('../../partials/header') %>

<div class="container py-5">
    <!-- Admin Header -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="admin-header p-4 rounded" style="background: linear-gradient(135deg, #1f1f1f 0%, #141414 100%); border: 1px solid #333;">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="mb-2"><i class="fas fa-users-cog me-2" style="color: var(--primary-color);"></i>User Management</h1>
                        <p class="mb-0 text-white">Manage all registered users</p>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <a href="/dashboard" class="btn btn-outline-light"><i class="fas fa-arrow-left me-2"></i>Back to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card p-4 rounded text-center" style="background-color: #1f1f1f; border: 1px solid #333;">
                <i class="fas fa-users fa-2x mb-3" style="color: var(--primary-color);"></i>
                <h2 class="mb-1"><%= users.length %></h2>
                <p class="text-white mb-0">Total Users</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card p-4 rounded text-center" style="background-color: #1f1f1f; border: 1px solid #333;">
                <i class="fas fa-user-shield fa-2x mb-3" style="color: #ffc107;"></i>
                <h2 class="mb-1"><%= users.filter(u => u.role === 'admin').length %></h2>
                <p class="text-white mb-0">Admins</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card p-4 rounded text-center" style="background-color: #1f1f1f; border: 1px solid #333;">
                <i class="fas fa-user fa-2x mb-3" style="color: #28a745;"></i>
                <h2 class="mb-1"><%= users.filter(u => u.role === 'user').length %></h2>
                <p class="text-white mb-0">Regular Users</p>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="row">
        <div class="col-12">
            <div class="table-card" style="background-color: #1f1f1f; border-radius: 10px; border: 1px solid #333; overflow: hidden;">
                <div class="p-3" style="background-color: #141414; border-bottom: 1px solid #333;">
                    <h5 class="mb-0"><i class="fas fa-users me-2"></i>All Users</h5>
                </div>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th style="color: white; border-color: #333;">Profile</th>
                                <th style="color: white; border-color: #333;">Username</th>
                                <th style="color: white; border-color: #333;">Email</th>
                                <th style="color: white; border-color: #333;">Role</th>
                                <th style="color: white; border-color: #333;">Joined</th>
                                <th style="color: white; border-color: #333;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(user => { %>
                                <tr style="border-color: #333;" class="<%= user._id.toString() === locals.user._id ? 'table-active' : '' %>">
                                    <td style="border-color: #333;">
                                        <img src="<%= user.profileImage || '/uploads/default-avatar.png' %>" alt="<%= user.username %>" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                                    </td>
                                    <td style="border-color: #333; color: white;">
                                        <strong><%= user.username %></strong>
                                        <% if (user._id.toString() === locals.user._id) { %>
                                            <span class="badge bg-info ms-1">You</span>
                                        <% } %>
                                    </td>
                                    <td style="border-color: #333; color: white;"><%= user.email %></td>
                                    <td style="border-color: #333;">
                                        <% if (user.role === 'admin') { %>
                                            <span class="badge" style="background-color: var(--primary-color);"><i class="fas fa-crown me-1"></i>Admin</span>
                                        <% } else { %>
                                            <span class="badge" style="background-color: #28a745;"><i class="fas fa-user me-1"></i>User</span>
                                        <% } %>
                                    </td>
                                    <td style="border-color: #333; color: white;"><%= new Date(user.createdAt).toLocaleDateString() %></td>
                                    <td style="border-color: #333;">
                                        <% if (user._id.toString() !== locals.user._id) { %>
                                            <div class="d-flex gap-2">
                                                <a href="/user/<%= user._id %>/blogs" class="btn btn-sm btn-outline-primary" title="View user's blogs"><i class="fas fa-blog"></i></a>

                                            </div>
                                        <% } else { %>
                                            <span class="text-muted">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .stat-card {
        transition: transform 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-5px);
    }
    .table {
        color: white;
    }
    .table thead th {
        border-bottom: 2px solid var(--primary-color);
    }
    .table td {
        border-color: #333;
        vertical-align: middle;
    }
    .table-active {
        background-color: #333 !important;
    }
</style>

<%- include('../../partials/footer') %>
