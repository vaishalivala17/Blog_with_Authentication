<%- include('../partials/header') %>

<!-- Hero Section -->
<section class="hero-section" style="background: linear-gradient(to bottom, rgba(0,0,0,0.3), #141414), url('https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80'); background-size: cover; background-position: center; padding: 150px 0 100px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-7">
                <h1 class="display-3 fw-bold mb-4" style="color: white;">Unlimited Movies, <br><span style="color: #E50914;">Blogs & More</span></h1>
                <p class="lead mb-4" style="color: #e0e0e0;">Read from anywhere, cancel anytime. Join millions of readers and writers worldwide.</p>
                <div class="d-flex gap-3">
                    <a href="/register" class="btn btn-netflix btn-lg px-4"><i class="fas fa-play me-2"></i>Get Started</a>
                    <a href="#blogs" class="btn btn-outline-light btn-lg px-4"><i class="fas fa-info-circle me-2"></i>Learn More</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Categories -->
<section class="py-5" style="background-color: #141414;">
    <div class="container">
        <h2 class="mb-4" style="color: white; font-size: 1.8rem;"><i class="fas fa-layer-group me-2" style="color: #E50914;"></i>Browse By Category</h2>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <a href="/category/Technology" class="text-decoration-none">
                    <div class="category-card p-4 rounded text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <i class="fas fa-laptop-code fa-2x mb-2" style="color: white;"></i>
                        <h5 class="mb-0" style="color: white;">Technology</h5>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/category/Lifestyle" class="text-decoration-none">
                    <div class="category-card p-4 rounded text-center" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                        <i class="fas fa-heart fa-2x mb-2" style="color: white;"></i>
                        <h5 class="mb-0" style="color: white;">Lifestyle</h5>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/category/Travel" class="text-decoration-none">
                    <div class="category-card p-4 rounded text-center" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                        <i class="fas fa-plane fa-2x mb-2" style="color: white;"></i>
                        <h5 class="mb-0" style="color: white;">Travel</h5>
                    </div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/category/Food" class="text-decoration-none">
                    <div class="category-card p-4 rounded text-center" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                        <i class="fas fa-utensils fa-2x mb-2" style="color: white;"></i>
                        <h5 class="mb-0" style="color: white;">Food</h5>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Blogs Section -->
<section id="blogs" class="py-5" style="background-color: #141414;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="color: white; font-size: 1.8rem;"><i class="fas fa-fire me-2" style="color: #E50914;"></i>Trending Blogs</h2>
            <a href="/search" class="btn btn-outline-netflix">View All <i class="fas fa-arrow-right ms-1"></i></a>
        </div>
        
        <% if (blogs && blogs.length > 0) { %>
            <div class="row g-4">
                <% blogs.forEach(blog => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="blog-card h-100" style="background-color: #1f1f1f; border-radius: 10px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                            <div class="blog-image-wrapper" style="position: relative; height: 200px; overflow: hidden;">
                                <img src="<%= blog.image || '/uploads/default-blog.jpg' %>" alt="<%= blog.title %>" style="width: 100%; height: 100%; object-fit: cover;">
                                <div class="blog-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.8));"></div>
                                <span class="badge" style="position: absolute; top: 10px; right: 10px; background-color: #E50914;"><%= blog.category %></span>
                            </div>
                            <div class="p-4">
                                <h5 class="mb-2" style="color: white; font-weight: 600;"><%= blog.title %></h5>
                                <p class="mb-3" style="font-size: 14px; line-height: 1.5; color: #e0e0e0;"><%= blog.content.substring(0, 100) %>...</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <img src="<%= blog.author.profileImage || '/uploads/default-avatar.png' %>" alt="<%= blog.author.username %>" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover;">
                                        <small style="color: #e0e0e0;"><%= blog.author.username %></small>
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <small style="color: #e0e0e0;"><i class="fas fa-eye me-1"></i><%= blog.views %></small>
                                        <small style="color: #e0e0e0;"><i class="fas fa-heart me-1" style="color: #E50914;"></i><%= blog.likes.length %></small>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <a href="/blog/<%= blog._id %>" class="btn btn-netflix w-100 mt-3" style="max-width: 200px;"><i class="fas fa-book-open me-2"></i>Read More</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-5" style="background-color: #1f1f1f; border-radius: 10px;">
                <i class="fas fa-blog fa-4x mb-3" style="color: #E50914;"></i>
                <h3 style="color: white;">No blogs yet</h3>
                <p style="color: #e0e0e0;">Be the first to create a blog!</p>
                <a href="/register" class="btn btn-netflix mt-2"><i class="fas fa-user-plus me-2"></i>Get Started</a>
            </div>
        <% } %>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5" style="background: linear-gradient(135deg, #1f1f1f 0%, #141414 100%);">
    <div class="container text-center">
        <h2 class="mb-3" style="color: white;">Ready to start writing?</h2>
        <p class="mb-4" style="color: #e0e0e0;">Join our community of writers and share your thoughts with the world.</p>
        <a href="/register" class="btn btn-netflix btn-lg px-5"><i class="fas fa-pen me-2"></i>Create Your Account</a>
    </div>
</section>

<style>
    .category-card {
        transition: transform 0.3s ease;
    }
    .category-card:hover {
        transform: translateY(-5px);
    }
    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(229, 9, 20, 0.3);
    }
</style>

<%- include('../partials/footer') %>
