<%- include('../partials/header') %>

<div class="auth-container" style="min-height: calc(100vh - 80px); display: flex; align-items: center; justify-content: center; padding: 50px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="auth-card" style="background-color: rgba(30, 30, 30, 0.95); padding: 40px; border-radius: 10px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5); border: 1px solid #333;">
                    <div class="text-center mb-4">
                        <h1 style="color: #E50914; font-size: 50px; font-weight: 700;"><i class="fas fa-play-circle"></i></h1>
                        <h2 class="mb-1" style="color: white; font-size: 2rem; font-weight: 600;">Sign In</h2>
                        <p style="color: #e0e0e0; font-size: 1rem;">Welcome back! Please sign in to continue.</p>
                    </div>
                    
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger" style="background-color: rgba(220, 53, 69, 0.2); border: 1px solid #dc3545; color: #f8d7da;">
                            <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                        </div>
                    <% } %>
                    
                    <% if (typeof message !== 'undefined' && message) { %>
                        <div class="alert alert-success" style="background-color: rgba(25, 135, 84, 0.2); border: 1px solid #198754; color: #75b798;">
                            <i class="fas fa-check-circle me-2"></i><%= message %>
                        </div>
                    <% } %>

                    <form action="/login" method="POST">
                        <div class="mb-4">
                            <label for="email" class="form-label" style="color: white; font-weight: 500;">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text" style="background-color: #333; border: 1px solid #444; color: #999;"><i class="fas fa-envelope"></i></span>
                                <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" required style="background-color: #333; border: 1px solid #444; color: white;">
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label for="password" class="form-label" style="color: white; font-weight: 500;">Password</label>
                            <div class="input-group">
                                <span class="input-group-text" style="background-color: #333; border: 1px solid #444; color: #999;"><i class="fas fa-lock"></i></span>
                                <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password" required style="background-color: #333; border: 1px solid #444; color: white;">
                            </div>
                        </div>
                        
                        <div class="text-center">
                            <button type="submit" class="btn btn-netflix py-2 mb-3" style="min-width: 200px; font-size: 1.1rem;"><i class="fas fa-sign-in-alt me-2"></i>Sign In</button>
                        </div>
                    </form>
                    
                    <div class="text-center">
                        <p style="color: #e0e0e0;" class="mb-0">Don't have an account? <a href="/register" style="color: #E50914; text-decoration: none; font-weight: 600;">Sign up now</a></p>
                    </div>
                    
                    <div class="mt-4 p-3" style="background-color: rgba(255, 255, 255, 0.05); border-radius: 5px; border: 1px solid #333;">
                        <p class="small mb-2" style="color: #e0e0e0; font-weight: 600;"><i class="fas fa-info-circle me-2" style="color: #E50914;"></i>Demo Accounts:</p>
                        <p class="small mb-1" style="color: #e0e0e0;"><strong style="color: #E50914;">User:</strong> user@test.com / password123</p>
                        <p class="small mb-0" style="color: #e0e0e0;"><strong style="color: #E50914;">Admin:</strong> admin@test.com / admin123</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        background-color: #333;
        border-color: #E50914;
        color: white;
        box-shadow: 0 0 0 0.2rem rgba(229, 9, 20, 0.25);
    }
    .form-control::placeholder {
        color: #666;
    }
    .form-label {
        font-size: 1rem;
    }
</style>

<%- include('../partials/footer') %>
