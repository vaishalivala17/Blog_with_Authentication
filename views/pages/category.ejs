<%- include('../partials/header') %>

<div class="container py-5">
    <!-- Category Header -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="page-title"><i class="fas fa-folder me-3"></i><%= category %></h1>
            <p class="page-subtitle">Browse all blogs in <strong style="color: #E50914;"><%= category %></strong> category</p>
        </div>
    </div>

    <!-- Category Navigation -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a href="/category/Technology" class="btn <%= category === 'Technology' ? 'btn-netflix' : 'btn-cat btn-tech' %>">
                    <i class="fas fa-laptop-code me-2"></i>Technology
                </a>
                <a href="/category/Lifestyle" class="btn <%= category === 'Lifestyle' ? 'btn-netflix' : 'btn-cat btn-life' %>">
                    <i class="fas fa-heart me-2"></i>Lifestyle
                </a>
                <a href="/category/Travel" class="btn <%= category === 'Travel' ? 'btn-netflix' : 'btn-cat btn-travel' %>">
                    <i class="fas fa-plane me-2"></i>Travel
                </a>
                <a href="/category/Food" class="btn <%= category === 'Food' ? 'btn-netflix' : 'btn-cat btn-food' %>">
                    <i class="fas fa-utensils me-2"></i>Food
                </a>
                <a href="/category/Health" class="btn <%= category === 'Health' ? 'btn-netflix' : 'btn-cat btn-health' %>">
                    <i class="fas fa-heartbeat me-2"></i>Health
                </a>
                <a href="/category/Business" class="btn <%= category === 'Business' ? 'btn-netflix' : 'btn-cat btn-biz' %>">
                    <i class="fas fa-briefcase me-2"></i>Business
                </a>
                <a href="/category/Entertainment" class="btn <%= category === 'Entertainment' ? 'btn-netflix' : 'btn-cat btn-ent' %>">
                    <i class="fas fa-film me-2"></i>Entertainment
                </a>
            </div>
        </div>
    </div>

    <!-- Blogs -->
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4" style="color: white; font-size: 1.8rem;">
                All <span style="color: #E50914;"><%= category %></span> Blogs 
                <span class="badge ms-2" style="background-color: #E50914; font-size: 0.9rem;"><%= blogs.length %></span>
            </h2>

            <% if (blogs && blogs.length > 0) { %>
                <div class="row g-4">
                    <% blogs.forEach(blog => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="blog-card h-100" style="background-color: #1f1f1f; border-radius: 10px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                                <div class="blog-image-wrapper" style="position: relative; height: 200px; overflow: hidden;">
                                    <img src="<%= blog.image || '/uploads/default-blog.jpg' %>" alt="<%= blog.title %>" style="width: 100%; height: 100%; object-fit: cover;">
                                    <div class="blog-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.8));"></div>
                                    <span class="badge" style="position: absolute; top: 10px; right: 10px; background-color: #E50914;">
                                        <i class="fas fa-tag me-1"></i><%= blog.category %>
                                    </span>
                                </div>
                                <div class="p-4">
                                    <h5 class="mb-2" style="color: white; font-weight: 600; font-size: 1.1rem;"><%= blog.title %></h5>
                                    <p class="mb-3" style="font-size: 14px; line-height: 1.5; color: #e0e0e0;"><%= blog.content.substring(0, 100) %>...</p>
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="d-flex align-items-center">
                                            <img src="<%= blog.author.profileImage || '/uploads/default-avatar.png' %>" alt="<%= blog.author.username %>" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover;">
                                            <small style="color: #e0e0e0;"><%= blog.author.username %></small>
                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <small style="color: #e0e0e0;"><i class="fas fa-eye me-1"></i><%= blog.views %></small>
                                            <small style="color: #e0e0e0;"><i class="fas fa-heart me-1" style="color: #E50914;"></i><%= blog.likes.length %></small>
                                        </div>
                                    </div>
                                    <div class="text-center">
                                        <a href="/blog/<%= blog._id %>" class="btn btn-netflix w-100 mt-2" style="max-width: 200px;">
                                            <i class="fas fa-book-open me-2"></i>Read More
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5" style="background-color: #1f1f1f; border-radius: 10px;">
                    <i class="fas fa-folder-open fa-4x mb-3" style="color: #E50914;"></i>
                    <h3 style="color: white;">No blogs in this category</h3>
                    <p style="color: #e0e0e0;">Be the first to create a blog in <%= category %>!</p>
                    <a href="/blog/create" class="btn btn-netflix mt-2">
                        <i class="fas fa-plus-circle me-2"></i>Create Blog
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<style>
    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(229, 9, 20, 0.3);
    }
    
    .btn-cat {
        background-color: #333;
        color: #e0e0e0;
        border: 2px solid #444;
        padding: 10px 20px;
        border-radius: 4px;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .btn-cat:hover {
        transform: scale(1.05);
    }
    
    .btn-cat.btn-tech {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    
    .btn-cat.btn-life {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border: none;
    }
    
    .btn-cat.btn-travel {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        border: none;
    }
    
    .btn-cat.btn-food {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        border: none;
    }
    
    .btn-cat.btn-health {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        border: none;
    }
    
    .btn-cat.btn-biz {
        background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);
        border: none;
    }
    
    .btn-cat.btn-ent {
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
        border: none;
    }
</style>

<%- include('../partials/footer') %>
