<%- include('../partials/header') %>

<div class="container py-5">
    <!-- Dashboard Header -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="dashboard-header p-4 rounded" style="background: linear-gradient(135deg, #1f1f1f 0%, #141414 100%); border: 1px solid #333;">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="mb-2" style="color: #ffffff; font-size: 2rem; font-weight: 700;"><i class="fas fa-tachometer-alt me-3" style="color: #E50914;"></i>My Dashboard</h1>
                        <p class="mb-0" style="color: #e0e0e0; font-size: 1.1rem;">Welcome back, <strong style="color: #E50914;"><%= user.username %></strong>!</p>
                        <% if (isAdmin) { %>
                            <span class="badge mt-2" style="background-color: #E50914; font-size: 0.9rem; padding: 8px 15px;"><i class="fas fa-crown me-1"></i>Admin</span>
                        <% } else { %>
                            <span class="badge mt-2" style="background-color: #28a745; font-size: 0.9rem; padding: 8px 15px;"><i class="fas fa-user me-1"></i>User</span>
                        <% } %>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <a href="/blog/create" class="btn btn-netflix" style="padding: 12px 25px; font-size: 1rem;"><i class="fas fa-plus me-2"></i>Create New Blog</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card p-4 rounded text-center" style="background-color: #1f1f1f; border: 1px solid #333;">
                <i class="fas fa-blog fa-2x mb-3" style="color: #E50914;"></i>
                <h2 class="mb-1" style="color: #ffffff; font-size: 2.5rem; font-weight: 700;"><%= blogs.length %></h2>
                <p class="mb-0" style="color: #e0e0e0; font-size: 1rem;">Total Blogs</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card p-4 rounded text-center" style="background-color: #1f1f1f; border: 1px solid #333;">
                <i class="fas fa-eye fa-2x mb-3" style="color: #4facfe;"></i>
                <h2 class="mb-1" style="color: #ffffff; font-size: 2.5rem; font-weight: 700;"><%= blogs.reduce((sum, blog) => sum + (blog.views || 0), 0) %></h2>
                <p class="mb-0" style="color: #e0e0e0; font-size: 1rem;">Total Views</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card p-4 rounded text-center" style="background-color: #1f1f1f; border: 1px solid #333;">
                <i class="fas fa-heart fa-2x mb-3" style="color: #f5576c;"></i>
                <h2 class="mb-1" style="color: #ffffff; font-size: 2.5rem; font-weight: 700;"><%= blogs.reduce((sum, blog) => sum + (blog.likes ? blog.likes.length : 0), 0) %></h2>
                <p class="mb-0" style="color: #e0e0e0; font-size: 1rem;">Total Likes</p>
            </div>
        </div>
    </div>

    <!-- Blogs List -->
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 style="color: #ffffff; font-size: 1.8rem; font-weight: 600;"><i class="fas fa-list me-2" style="color: #E50914;"></i>My Blogs</h2>
                <% if (isAdmin) { %>
                    <a href="/admin/users" class="btn btn-outline-netflix"><i class="fas fa-users me-2"></i>Manage Users</a>
                <% } %>
            </div>

            <% if (blogs && blogs.length > 0) { %>
                <div class="table-responsive">
                    <table class="table" style="border-color: #333; ">
                        <thead style="background-color: #141414;">
                            <tr>
                                <th style="color: #ffffff; border-color: #333;">Image</th>
                                <th style="color: #ffffff; border-color: #333;">Title</th>
                                <th style="color: #ffffff; border-color: #333;">Category</th>
                                <th style="color: #ffffff; border-color: #333;">Status</th>
                                <th style="color: #ffffff; border-color: #333;">Views</th>
                                <th style="color: #ffffff; border-color: #333;">Likes</th>
                                <th style="color: #ffffff; border-color: #333;">Date</th>
                                <th style="color: #ffffff; border-color: #333;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% blogs.forEach(blog => { %>
                                <tr style="border-color: #333;">
                                    <td style="border-color: #333;">
                                        <img src="<%= blog.image || '/uploads/default-blog.jpg' %>" alt="<%= blog.title || 'Blog' %>" style="width: 60px; height: 40px; object-fit: cover; border-radius: 5px;">
                                    </td>
                                    <td style="border-color: #333; color: #e0e0e0; font-weight: 500;">
                                        <a href="/blog/<%= blog._id %>" style="color: #e0e0e0; text-decoration: none; font-weight: 500;"><%= blog.title ? (blog.title.length > 30 ? blog.title.substring(0, 30) + '...' : blog.title) : 'Untitled' %></a>
                                        <% if (!isAdmin && blog.author && blog.author.username !== user.username) { %>
                                            <br><small style="color: #aaaaaa;">by <%= blog.author.username %></small>
                                        <% } %>
                                    </td>
                                    <td style="border-color: #333; color: #e0e0e0;"><%= blog.category || 'General' %></td>
                                    <td style="border-color: #333;">
                                        <% if (blog.status === 'published') { %>
                                            <span class="badge" style="background-color: #28a745;"><i class="fas fa-check me-1"></i>Published</span>
                                        <% } else { %>
                                            <span class="badge" style="background-color: #ffc107; color: black;"><i class="fas fa-edit me-1"></i>Draft</span>
                                        <% } %>
                                    </td>
                                    <td style="border-color: #333; color: #e0e0e0;"><i class="fas fa-eye me-1" style="color: #4facfe;"></i><%= blog.views || 0 %></td>
                                    <td style="border-color: #333; color: #e0e0e0;"><i class="fas fa-heart me-1" style="color: #E50914;"></i><%= blog.likes ? blog.likes.length : 0 %></td>
                                    <td style="border-color: #333; color: #e0e0e0;"><%= blog.createdAt ? new Date(blog.createdAt).toLocaleDateString() : 'N/A' %></td>
                                    <td style="border-color: #333;">
                                        <div class="btn-group" role="group">
                                            <a href="/blog/<%= blog._id %>" class="btn btn-sm" style="background-color: #4facfe; color: #ffffff; border: none;" title="View">
                                                <i class="fas fa-eye"></i> View
                                            </a>
                                            <a href="/blog/edit/<%= blog._id %>" class="btn btn-sm" style="background-color: #f0ad4e; color: #ffffff; border: none;" title="Edit">
                                                <i class="fas fa-edit"></i> Edit
                                            </a>
                                            <form action="/blog/delete/<%= blog._id %>" method="POST" style="display: inline;">
                                                <button type="submit" class="btn btn-sm" style="background-color: #dc3545; color: #ffffff; border: none;" title="Delete" onclick="return confirm('Are you sure you want to delete this blog?')">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-5" style="background-color: #1f1f1f; border-radius: 10px;">
                    <i class="fas fa-blog fa-4x mb-3" style="color: #E50914;"></i>
                    <h3 style="color: #ffffff;">No blogs yet</h3>
                    <p style="color: #e0e0e0;">Start creating your first blog!</p>
                    <a href="/blog/create" class="btn btn-netflix mt-2"><i class="fas fa-plus me-2"></i>Create Blog</a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<style>
    .stat-card {
        transition: transform 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-5px);
    }
    .table {
        color: #ffffff;
    }
    .table thead th {
        border-bottom: 2px solid #E50914;
    }
    .table td {
        border-color: #333;
        vertical-align: middle;
    }
    .btn-group .btn {
        margin-right: 2px;
    }
    .btn-group .btn:last-child {
        margin-right: 0;
    }
</style>

<%- include('../partials/footer') %>
