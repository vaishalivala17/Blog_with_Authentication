<%- include('../partials/header') %>

<div class="container py-5">
    <!-- Search Header -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="search-header p-5 rounded text-center" style="background: linear-gradient(135deg, #1f1f1f 0%, #141414 100%); border: 1px solid #333;">
                <h1 class="page-title"><i class="fas fa-search me-3"></i>Search Blogs</h1>
                <p class="page-subtitle">Find blogs by title, content, or tags</p>
                <form action="/search" method="GET" class="mt-4">
                    <div class="row justify-content-center">
                        <div class="col-md-8">
                            <div class="input-group">
                                <input type="text" class="form-control" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" placeholder="Search for blogs..." style="background-color: #333; border: 1px solid #444; color: white; height: 50px;">
                                <button type="submit" class="btn btn-netflix px-4"><i class="fas fa-search"></i></button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Search Results -->
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4" style="color: white; font-size: 1.8rem;">
                <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                    Results for "<span style="color: #E50914;"><%= searchQuery %></span>"
                <% } else { %>
                    All Published Blogs
                <% } %>
                <span class="badge ms-2" style="background-color: #E50914; font-size: 0.9rem;"><%= blogs.length %></span>
            </h2>

            <% if (blogs && blogs.length > 0) { %>
                <div class="row g-4">
                    <% blogs.forEach(blog => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="blog-card h-100" style="background-color: #1f1f1f; border-radius: 10px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                                <div class="blog-image-wrapper" style="position: relative; height: 200px; overflow: hidden;">
                                    <img src="<%= blog.image || '/uploads/default-blog.jpg' %>" alt="<%= blog.title %>" style="width: 100%; height: 100%; object-fit: cover;">
                                    <div class="blog-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.8));"></div>
                                    <span class="badge" style="position: absolute; top: 10px; right: 10px; background-color: #E50914;"><%= blog.category %></span>
                                </div>
                                <div class="p-4">
                                    <h5 class="mb-2" style="color: white; font-weight: 600; font-size: 1.1rem;"><%= blog.title %></h5>
                                    <p class="mb-3" style="font-size: 14px; line-height: 1.5; color: #e0e0e0;"><%= blog.content.substring(0, 100) %>...</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <img src="<%= blog.author.profileImage || '/uploads/default-avatar.png' %>" alt="<%= blog.author.username %>" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover;">
                                            <small style="color: #e0e0e0;"><%= blog.author.username %></small>
                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <small style="color: #e0e0e0;"><i class="fas fa-eye me-1"></i><%= blog.views %></small>
                                            <small style="color: #e0e0e0;"><i class="fas fa-heart me-1" style="color: #E50914;"></i><%= blog.likes.length %></small>
                                        </div>
                                    </div>
                                    <div class="text-center">
                                        <a href="/blog/<%= blog._id %>" class="btn btn-netflix w-100 mt-3" style="max-width: 200px;"><i class="fas fa-book-open me-2"></i>Read More</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5" style="background-color: #1f1f1f; border-radius: 10px;">
                    <i class="fas fa-search fa-4x mb-3" style="color: #E50914;"></i>
                    <h3 style="color: white;">No blogs found</h3>
                    <p style="color: #e0e0e0;">Try different search terms or browse categories</p>
                    <a href="/" class="btn btn-netflix mt-2"><i class="fas fa-home me-2"></i>Browse All Blogs</a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<style>
    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(229, 9, 20, 0.3);
    }
    .form-control:focus {
        background-color: #333;
        border-color: #E50914;
        color: white;
        box-shadow: 0 0 0 0.2rem rgba(229, 9, 20, 0.25);
    }
    .form-control::placeholder {
        color: #666;
    }
</style>

<%- include('../partials/footer') %>
